{
  "name": "signalkite",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "npm --prefix mobile run start",
    "mobile": "npm --prefix mobile run start",
    "mobile:web": "npm --prefix mobile run web",
    "mobile:typecheck": "npm --prefix mobile run typecheck",
    "mailer": "npm --prefix notification-gateway run start",
    "mailer:dev": "npm --prefix notification-gateway run dev",
    "backend": "cd backend && .\\.venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8000",
    "backend:dev": "cd backend && .\\.venv\\Scripts\\python.exe -m uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "backend:test": "cd backend && .\\.venv\\Scripts\\python.exe -m pytest -q",
    "backend:migrate": "cd backend && .\\.venv\\Scripts\\python.exe -m alembic upgrade head",
    "worker": "cd backend && .\\.venv\\Scripts\\python.exe worker.py"
  }
}
